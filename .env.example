# === Gemini (Google AI Studio) ===
GEMINI_API_KEY=                        # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash

# === Chatwoot ===
CHATWOOT_BASE_URL=https://chatwoot-pdv.up.railway.app
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=                     # Obtenido al crear el inbox en Chatwoot
CHATWOOT_API_ACCESS_TOKEN=             # Token del bot-user (GET /api/v1/profile)
CHATWOOT_HMAC_TOKEN=                   # Generado al crear el Agent Bot en Chatwoot
CHATWOOT_BOT_USER_ID=                  # ID del bot-user en Chatwoot

# === Google Calendar ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=                  # Generado por scripts/google_oauth_setup.py
GOOGLE_CALENDAR_ID=primary

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=                  # Service role key, NO la anon

# === App ===
CLINIC_NAME=PDV Policlínica Dental del Vallès
CLINIC_PHONE_HUMAN=+34677523665
TIMEZONE=Europe/Madrid
SLOT_DURATION_MINUTES=30
WORKING_HOURS_START=09:00
WORKING_HOURS_END=20:00
WORKING_DAYS=1,2,3,4                   # Lun-Jue (1=lunes ISO)
INTERNAL_API_TOKEN=                    # String aleatorio para proteger /internal/run-reminders
LOG_LEVEL=INFO

# === Variables para el servicio CHATWOOT en Railway (NO van aquí, van en el servicio Chatwoot) ===
